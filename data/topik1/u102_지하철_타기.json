  "dialogue": [
    {
      "line": 1,
      "role": "손님",
      "ko": "실례합니다. 명동역에 가려면 어떻게 해야 해요?",
      "romanization": "",
      "vi": "Xin lỗi. Để đến ga Myeong-dong thì phải làm sao ạ?",
      "en": "Excuse me. How do I get to Myeong-dong Station?",
      "zh": "不好意思，请问去明洞站怎么走？"
    },
    {
      "line": 2,
      "role": "직원",
      "ko": "4호선을 타세요. 여기서 두 정거장이에요.",
      "romanization": "",
      "vi": "Anh/chị lên tàu tuyến số 4. Từ đây đi hai ga thôi.",
      "en": "Take Line 4. It's two stops from here.",
      "zh": "坐4号线，从这里两站就到了。"
    },
    {
      "line": 3,
      "role": "손님",
      "ko": "환승해야 해요?",
      "romanization": "",
      "vi": "Có phải chuyển tàu không ạ?",
      "en": "Do I need to transfer?",
      "zh": "需要换乘吗？"
    },
    {
      "line": 4,
      "role": "직원",
      "ko": "아니요, 환승 안 해도 돼요. 바로 가요.",
      "romanization": "",
      "vi": "Không, không cần chuyển tàu đâu. Đi thẳng luôn.",
      "en": "No, you don't need to transfer. Go straight.",
      "zh": "不用，不用换乘，直接就到了。"
    },
    {
      "line": 5,
      "role": "손님",
      "ko": "교통카드가 없어요. 어디서 살 수 있어요?",
      "romanization": "",
      "vi": "Tôi không có thẻ giao thông. Có thể mua ở đâu ạ?",
      "en": "I don't have a transportation card. Where can I buy one?",
      "zh": "我没有交通卡，在哪里可以买？"
    },
    {
      "line": 6,
      "role": "직원",
      "ko": "저기 자동판매기에서 사세요.",
      "romanization": "",
      "vi": "Mua ở máy bán tự động kia đi.",
      "en": "Buy one at the vending machine over there.",
      "zh": "在那边的自动售票机买。"
    },
    {
      "line": 7,
      "role": "손님",
      "ko": "감사합니다. 출구는 어디예요?",
      "romanization": "",
      "vi": "Cảm ơn anh/chị. Lối ra ở đâu ạ?",
      "en": "Thank you. Where's the exit?",
      "zh": "谢谢。出口在哪里？"
    },
    {
      "line": 8,
      "role": "직원",
      "ko": "4번 출구로 나가세요.",
      "romanization": "",
      "vi": "Ra lối số 4 nhé.",
      "en": "Go out through Exit 4.",
      "zh": "从4号出口出去。"
    }
  ],
