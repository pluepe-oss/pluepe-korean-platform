  "dialogue": [
    {
      "line": 1,
      "role": "점원",
      "ko": "어서 오세요. 뭘 찾으세요?",
      "romanization": "eoseo oseyo. mwol chajeuseyo?",
      "vi": "Xin chào! Quý khách đang tìm gì ạ?",
      "en": "Welcome! How can I help you?",
      "zh": "欢迎光临！您想找什么样的衣服？"
    },
    {
      "line": 2,
      "role": "손님",
      "ko": "티셔츠를 찾고 있어요.",
      "romanization": "tisyeocheureul chatgo isseoyo.",
      "vi": "Tôi đang tìm áo thun.",
      "en": "I'm looking for a T-shirt.",
      "zh": "我在找T恤。"
    },
    {
      "line": 3,
      "role": "점원",
      "ko": "어떤 색깔을 원하세요?",
      "romanization": "eotteon saekkkareul wonhaseyo?",
      "vi": "Anh/Chị muốn tìm màu gì ạ?",
      "en": "What color would you like?",
      "zh": "您想要什么颜色的?"
    },
    {
      "line": 4,
      "role": "손님",
      "ko": "흰색이나 파란색이요. 이거 얼마예요?",
      "romanization": "huinsaegina paransaegieyo. igeo eolmayeyo?",
      "vi": "Màu trắng hoặc màu xanh dương. Cái này bao nhiêu tiền ạ?",
      "en": "White or blue. How much is this?",
      "zh": "白色或者蓝色的。这个多少钱?"
    },
    {
      "line": 5,
      "role": "점원",
      "ko": "이만 원이에요. 입어보세요.",
      "romanization": "iman wonieoyo. ibeobaseyo.",
      "vi": "Giá là 20.000 won. Anh/Chị mặc thử đi ạ.",
      "en": "It's 20,000 won. You can try it on.",
      "zh": "两万韩元。您可以试穿一下。"
    },
    {
      "line": 6,
      "role": "손님",
      "ko": "좀 커요. 더 작은 사이즈 있어요?",
      "romanization": "jom keoyo. deo jageun saijeu isseoyo?",
      "vi": "Hơi rộng một chút. Có size nhỏ hơn không?",
      "en": "It's a bit big. Do you have a smaller size?",
      "zh": "有点儿大。有小一点儿的吗?"
    },
    {
      "line": 7,
      "role": "점원",
      "ko": "네, 여기 있어요.",
      "romanization": "ne, yeogi isseoyo.",
      "vi": "Vâng, của Anh/Chị đây ạ.",
      "en": "Yes, here you go.",
      "zh": "有的,给您。"
    },
    {
      "line": 8,
      "role": "손님",
      "ko": "좋아요. 이걸로 할게요.",
      "romanization": "johayo. igeollo halgeyo.",
      "vi": "Được rồi. Tôi sẽ lấy cái này.",
      "en": "Great. I'll take this one.",
      "zh": "好的,那我就买这件。"
