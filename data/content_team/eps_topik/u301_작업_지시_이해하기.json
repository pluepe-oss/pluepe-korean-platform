  "dialogue": [
    {
      "line": 1,
      "role": "감독",
      "ko": "오늘은 A라인에서 일하세요.",
      "romanization": "",
      "vi": "Hôm nay hãy làm ở dây chuyền A.",
      "th": "วันนี้ทำงานที่สายการผลิต A นะครับ",
      "id": "Hari ini bekerja di Lini A."
    },
    {
      "line": 2,
      "role": "근로자",
      "ko": "네, 알겠습니다. 무슨 일을 해요?",
      "romanization": "",
      "vi": "Dạ, tôi hiểu. Tôi làm việc gì ạ?",
      "th": "ครับ รับทราบครับ ต้องทำหน้าที่อะไรบ้างครับ?",
      "id": "Ya, baik. Pekerjaan apa yang dilakukan?"
    },
    {
      "line": 3,
      "role": "감독",
      "ko": "부품을 조립하세요. 이 설명서를 보세요.",
      "romanization": "",
      "vi": "Hãy lắp ráp linh kiện. Hãy xem hướng dẫn này.",
      "th": "ให้ประกอบชิ้นส่วนครับ ดูคู่มือการทำงานเล่มนี้ครับ",
      "id": "Rakitlah komponen. Lihatlah manual ini."
    },
    {
      "line": 4,
      "role": "근로자",
      "ko": "순서대로 하면 돼요?",
      "romanization": "",
      "vi": "Tôi làm theo thứ tự được không ạ?",
      "th": "ทำตามลำดับขั้นตอนใช่ไหมครับ?",
      "id": "Apakah boleh dilakukan sesuai urutan?"
    },
    {
      "line": 5,
      "role": "감독",
      "ko": "네, 맞아요. 천천히 해도 괜찮아요.",
      "romanization": "",
      "vi": "Đúng rồi. Làm chậm cũng được.",
      "th": "ใช่ครับ ถูกต้องครับ ค่อยๆ ทำไปก็ได้ครับ ไม่ต้องรีบ",
      "id": "Ya, benar. Tidak apa-apa pelan-pelan."
    },
    {
      "line": 6,
      "role": "근로자",
      "ko": "모르면 물어봐도 돼요?",
      "romanization": "",
      "vi": "Không biết thì có thể hỏi không ạ?",
      "th": "ถ้าไม่เข้าใจ สอบถามได้ไหมครับ?",
      "id": "Boleh bertanya kalau tidak tahu?"
    },
    {
      "line": 7,
      "role": "감독",
      "ko": "네, 언제든지 물어보세요.",
      "romanization": "",
      "vi": "Có, hãy hỏi bất cứ lúc nào.",
      "th": "ได้ครับ สอบถามได้ตลอดเวลาเลยครับ",
      "id": "Ya, silakan tanya kapan saja."
    },
    {
      "line": 8,
      "role": "근로자",
      "ko": "끝나면 어떻게 해요?",
      "romanization": "",
      "vi": "Xong rồi thì phải làm sao ạ?",
      "th": "ถ้าทำเสร็จแล้ว ต้องทำยังไงต่อครับ?",
      "id": "Bagaimana kalau sudah selesai?"
    },
    {
      "line": 9,
      "role": "감독",
      "ko": "끝나면 저한테 바로 말하세요.",
      "romanization": "",
      "vi": "Xong thì nói với tôi ngay.",
      "th": "พอเสร็จแล้ว ให้รีบบอกผมทันทีเลยนะ",
      "id": "Kalau sudah selesai, langsung bicara ke saya."
    },
    {
      "line": 10,
      "role": "근로자",
      "ko": "네, 다 끝나면 알려 드릴게요.",
      "romanization": "",
      "vi": "Vâng, tôi sẽ báo lại khi hoàn thành.",
      "th": "ครับ ถ้าเสร็จเรียบร้อยแล้วจะแจ้งให้ทราบครับ",
      "id": "Ya, saya akan beri tahu kalau sudah selesai."
    }
  ],
